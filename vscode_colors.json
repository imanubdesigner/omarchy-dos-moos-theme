{
  "$schema": "vscode://schemas/color-theme",
  "name": "Omarchy",
  "type": "dark",
  "colors": {
    "foreground": "#A5B5AB",
    "focusBorder": "#819890",
    "errorForeground": "#F0334A",
    "descriptionForeground": "#72856C",
    "icon.foreground": "#A5B5AB",
    "selection.background": "#59594B",
    "widget.shadow": "#00000066",

    "editor.background": "#131516",
    "editor.foreground": "#F8EBE3",
    "editorLineNumber.foreground": "#3A4849",
    "editorLineNumber.activeForeground": "#F4E276",
    "editorCursor.foreground": "#F4E276",
    "editor.lineHighlightBackground": "#1C1C1A",
    "editor.selectionBackground": "#59594B",
    "editor.selectionHighlightBackground": "#3A484980",
    "editor.wordHighlightBackground": "#3A484960",
    "editor.findMatchBackground": "#667761",
    "editor.findMatchHighlightBackground": "#3A4849",
    "editorWhitespace.foreground": "#273236",
    "editorIndentGuide.background1": "#273236",
    "editorIndentGuide.activeBackground1": "#3A4849",
    "editorBracketMatch.background": "#273236",
    "editorBracketMatch.border": "#819890",
    "editorError.foreground": "#F0334A",
    "editorWarning.foreground": "#F4E276",
    "editorInfo.foreground": "#819890",
    "editorGutter.modifiedBackground": "#F4E276",
    "editorGutter.addedBackground": "#819890",
    "editorGutter.deletedBackground": "#F0334A",

    "editorWidget.background": "#1C1C1A",
    "editorWidget.border": "#3A4849",
    "editorSuggestWidget.background": "#1C1C1A",
    "editorSuggestWidget.border": "#3A4849",
    "editorSuggestWidget.selectedBackground": "#273236",
    "editorHoverWidget.background": "#1C1C1A",
    "editorHoverWidget.border": "#3A4849",

    "activityBar.background": "#131516",
    "activityBar.foreground": "#F8EBE3",
    "activityBar.inactiveForeground": "#72856C",
    "activityBarBadge.background": "#819890",
    "activityBarBadge.foreground": "#131516",

    "sideBar.background": "#0F1011",
    "sideBar.foreground": "#A5B5AB",
    "sideBarTitle.foreground": "#F8EBE3",
    "sideBarSectionHeader.background": "#131516",
    "sideBarSectionHeader.foreground": "#A5B5AB",

    "statusBar.background": "#1C1C1A",
    "statusBar.foreground": "#A5B5AB",
    "statusBar.noFolderBackground": "#1C1C1A",
    "statusBar.debuggingBackground": "#F0334A",
    "statusBar.debuggingForeground": "#131516",
    "statusBarItem.remoteBackground": "#819890",
    "statusBarItem.remoteForeground": "#131516",

    "titleBar.activeBackground": "#131516",
    "titleBar.activeForeground": "#F8EBE3",
    "titleBar.inactiveBackground": "#131516",
    "titleBar.inactiveForeground": "#72856C",

    "tab.activeBackground": "#131516",
    "tab.inactiveBackground": "#0F1011",
    "tab.activeForeground": "#F8EBE3",
    "tab.inactiveForeground": "#72856C",
    "tab.activeBorderTop": "#F4E276",
    "tab.border": "#1C1C1A",
    "editorGroupHeader.tabsBackground": "#0F1011",
    "editorGroupHeader.noTabsBackground": "#0F1011",

    "panel.background": "#131516",
    "panel.border": "#273236",
    "panelTitle.activeForeground": "#F8EBE3",
    "panelTitle.inactiveForeground": "#72856C",

    "terminal.background": "#131516",
    "terminal.foreground": "#F8EBE3",
    "terminalCursor.foreground": "#F4E276",
    "terminal.ansiBlack": "#131516",
    "terminal.ansiRed": "#F0334A",
    "terminal.ansiGreen": "#819890",
    "terminal.ansiYellow": "#F4E276",
    "terminal.ansiBlue": "#A5B5AB",
    "terminal.ansiMagenta": "#72856C",
    "terminal.ansiCyan": "#819890",
    "terminal.ansiWhite": "#A5B5AB",
    "terminal.ansiBrightBlack": "#3A4849",
    "terminal.ansiBrightRed": "#F0334A",
    "terminal.ansiBrightGreen": "#A5B5AB",
    "terminal.ansiBrightYellow": "#F4E276",
    "terminal.ansiBrightBlue": "#A5B5AB",
    "terminal.ansiBrightMagenta": "#819890",
    "terminal.ansiBrightCyan": "#A5B5AB",
    "terminal.ansiBrightWhite": "#F8EBE3",

    "input.background": "#1C1C1A",
    "input.foreground": "#F8EBE3",
    "input.border": "#3A4849",
    "input.placeholderForeground": "#72856C",
    "inputOption.activeBorder": "#819890",
    "dropdown.background": "#1C1C1A",
    "dropdown.foreground": "#F8EBE3",
    "dropdown.border": "#3A4849",

    "list.activeSelectionBackground": "#273236",
    "list.activeSelectionForeground": "#F8EBE3",
    "list.inactiveSelectionBackground": "#1C1C1A",
    "list.hoverBackground": "#1C1C1A",
    "list.highlightForeground": "#F4E276",
    "list.focusBackground": "#273236",

    "button.background": "#819890",
    "button.foreground": "#131516",
    "button.hoverBackground": "#A5B5AB",
    "badge.background": "#819890",
    "badge.foreground": "#131516",

    "scrollbarSlider.background": "#3A484980",
    "scrollbarSlider.hoverBackground": "#3A4849",
    "scrollbarSlider.activeBackground": "#667761",

    "breadcrumb.foreground": "#72856C",
    "breadcrumb.focusForeground": "#F8EBE3",
    "menu.background": "#1C1C1A",
    "menu.foreground": "#F8EBE3",
    "menu.selectionBackground": "#273236",

    "gitDecoration.modifiedResourceForeground": "#F4E276",
    "gitDecoration.addedResourceForeground": "#819890",
    "gitDecoration.deletedResourceForeground": "#F0334A",
    "gitDecoration.untrackedResourceForeground": "#B8CE76",
    "gitDecoration.ignoredResourceForeground": "#3A4849",
    "gitDecoration.conflictingResourceForeground": "#F4E276"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "fontStyle": "italic", "foreground": "#72856C" }
    },
    {
      "name": "Variables / Parameters",
      "scope": ["variable", "variable.parameter", "entity.name.variable", "meta.definition.variable.name"],
      "settings": { "foreground": "#F8EBE3" }
    },
    {
      "name": "Properties / Members",
      "scope": ["variable.other.property", "variable.other.object.property", "support.variable.property", "meta.object-literal.key"],
      "settings": { "foreground": "#819890" }
    },
    {
      "name": "Keywords / Storage",
      "scope": ["keyword", "storage", "storage.type", "storage.modifier", "keyword.operator.new", "keyword.operator.expression"],
      "settings": { "foreground": "#F4E276" }
    },
    {
      "name": "Control Keywords",
      "scope": ["keyword.control", "keyword.control.flow", "keyword.control.import", "keyword.control.from", "keyword.control.as", "variable.language.this", "variable.language.self"],
      "settings": { "foreground": "#8FB87A" }
    },
    {
      "name": "Functions / Methods",
      "scope": ["entity.name.function", "support.function", "meta.function-call.generic", "variable.function"],
      "settings": { "foreground": "#A5B5AB" }
    },
    {
      "name": "Types / Classes",
      "scope": ["entity.name.type", "entity.name.class", "entity.name.namespace", "support.type", "support.class", "entity.other.inherited-class"],
      "settings": { "foreground": "#819890" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template", "punctuation.definition.string"],
      "settings": { "foreground": "#B8CE76" }
    },
    {
      "name": "String escapes / regex",
      "scope": ["constant.character.escape", "string.regexp", "constant.other.placeholder"],
      "settings": { "foreground": "#819890" }
    },
    {
      "name": "Numbers / Constants",
      "scope": ["constant.numeric", "constant.language", "constant.language.boolean", "constant.language.null", "support.constant"],
      "settings": { "foreground": "#E0C15C" }
    },
    {
      "name": "Operators / Punctuation",
      "scope": ["keyword.operator", "punctuation", "meta.brace", "punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#A5B5AB" }
    },
    {
      "name": "Tags",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#F4E276" }
    },
    {
      "name": "Tag attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#819890" }
    },
    {
      "name": "Decorators / Annotations",
      "scope": ["meta.decorator", "entity.name.function.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#E0C15C" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#F0334A" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "fontStyle": "strikethrough", "foreground": "#72856C" }
    },
    {
      "name": "Markup heading",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "fontStyle": "bold", "foreground": "#F4E276" }
    },
    {
      "name": "Markup bold",
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold", "foreground": "#F8EBE3" }
    },
    {
      "name": "Markup italic",
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic", "foreground": "#F8EBE3" }
    },
    {
      "name": "Markup link / inserted / deleted",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#819890" }
    },
    {
      "name": "Markup inserted",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#819890" }
    },
    {
      "name": "Markup deleted",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#F0334A" }
    }
  ]
}
